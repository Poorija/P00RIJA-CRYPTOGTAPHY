# Copy to .env before running Docker Compose if you want stable TURN and Web Push settings.
# Generate stable VAPID keys with:
#   npx web-push generate-vapid-keys

TURN_USER=poorija
TURN_PASSWORD=change-me
TURN_REALM=poorija.local
TURN_SERVER_NAME=poorija-coturn

# Use the LAN IP or public domain clients can actually reach.
CHAT_TURN_URL=turn:127.0.0.1:3478?transport=udp

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@poorija.local
